# ── Auth-Luiz ─────────────────────────────────────────────────────────────────
AUTHLUIZ_DB_USER=USUARIO_BANCO_DE_DADOS
AUTHLUIZ_DB_PASSWORD=SENHA_BANCO_DE_DADOS
AUTHLUIZ_SETUP_MASTER_KEY=HASH-SECRET-KEY

GOOGLE_OAUTH_CLIENT_ID=client-id-do-google.apps.googleusercontent.com

JWT_EXPIRATION_MINUTES=120
JWT_RSA_PRIVATE_KEY=BASE64_DA_CHAVE_PRIVADA_PEM
JWT_RSA_PUBLIC_KEY=BASE64_DA_CHAVE_PUBLICA_PEM

# ── PermLuiz ──────────────────────────────────────────────────────────────────
PERMLUIZ_DB_USER=USUARIO_BANCO_DE_DADOS
PERMLUIZ_DB_PASSWORD=SENHA_BANCO_DE_DADOS
PERMLUIZ_SETUP_MASTER_KEY=OUTRO-HASH-SECRET-KEY

# Chave compartilhada para chamadas server-to-server entre AuthLuiz e PermLuiz
# Gere um valor aleatório seguro, ex: openssl rand -hex 32
AUTH_LUIZ_SERVICE_KEY=CHAVE-SERVICO-ALEATORIA

# ── Auditoria ─────────────────────────────────────────────────────────────────
# Logs de SEGURANÇA (login, senha, conta deletada) são sempre registrados.
# AUDITORIA_ATIVIDADE controla logs opcionais (edições de perfil, roles, permissões).
AUDITORIA_ATIVIDADE=true
# Dias de retenção dos logs antes da limpeza automática diária (03:00) em cada serviço
AUDITORIA_RETENCAO_DIAS=90

# ── pgAdmin ────────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
