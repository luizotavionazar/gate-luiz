SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5433/permluiz
SPRING_DATASOURCE_USERNAME=USUARIO_BANCO_DE_DADOS
SPRING_DATASOURCE_PASSWORD=SENHA_BANCO_DE_DADOS

# URI do endpoint JWKS do Auth-Luiz (em dev, Auth-Luiz deve estar rodando na porta 8080)
AUTH_LUIZ_JWKS_URI=http://localhost:8080/auth/.well-known/jwks.json

# Integração server-to-server com o Auth-Luiz
AUTH_LUIZ_BASE_URL=http://localhost:8080
# Deve ser idêntica à AUTH_LUIZ_SERVICE_KEY do AuthLuiz
AUTH_LUIZ_SERVICE_KEY=

# ── Auditoria ──────────────────────────────────────────────────────────────────
# Controla logs de atividade de admin (criação/remoção de roles, permissões e atribuições)
AUDITORIA_ATIVIDADE=true
# Dias de retenção dos logs antes da limpeza automática diária (03:00)
AUDITORIA_RETENCAO_DIAS=90
