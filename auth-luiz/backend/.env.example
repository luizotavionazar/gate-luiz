APP_SETUP_MASTER_KEY=HASH-SECRET-KEY

SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/authluiz
SPRING_DATASOURCE_USERNAME=authluiz
SPRING_DATASOURCE_PASSWORD=luizauth

JWT_EXPIRATION_MINUTES=120
# Chaves RSA (PKCS#8) em base64
JWT_RSA_PRIVATE_KEY=BASE64_DA_CHAVE_PRIVADA_PEM
JWT_RSA_PUBLIC_KEY=BASE64_DA_CHAVE_PUBLICA_PEM

GOOGLE_OAUTH_CLIENT_ID=client-id-do-google.apps.googleusercontent.com

# Opcional: URL interna do PermLuiz (habilita o botão "Painel de Controle" na tela de conta)
# Em Docker, usar o hostname interno: http://permluiz-backend:8080
# Em standalone, usar a porta exposta: http://localhost:8081
PERM_LUIZ_URL=

# Chave compartilhada com o PermLuiz para chamadas server-to-server (/auth/interno/**)
# Deve ser idêntica à AUTH_LUIZ_SERVICE_KEY do PermLuiz
AUTH_LUIZ_SERVICE_KEY=

# ── Auditoria ──────────────────────────────────────────────────────────────────
# Logs de SEGURANÇA (login, senha, conta deletada) são sempre registrados.
# AUDITORIA_ATIVIDADE controla apenas logs de atividade (edições de perfil).
AUDITORIA_ATIVIDADE=true
# Dias de retenção dos logs antes da limpeza automática diária (03:00)
AUDITORIA_RETENCAO_DIAS=90

# ── Mensagens via Twilio (WhatsApp ou SMS) ─────────────────────────────────────
# Necessário para verificação de telefone (PATCH /auth/me/telefone).
# Se não configurado, a mensagem não é enviada (erro logado, HTTP não afetado).
#
# TWILIO_CANAL: 'whatsapp' (padrão) ou 'sms'
#
# Sandbox WhatsApp (dev, sem custo):
#   1. Acesse console.twilio.com → Messaging → Try it out → Send a WhatsApp message
#   2. O destinatário envia a palavra-chave exibida para +1 415 523 8886 no WhatsApp
#   3. Use as credenciais abaixo:
#   TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   TWILIO_FROM_NUMBER=+14155238886   # número sandbox WhatsApp da Twilio
#   TWILIO_CANAL=whatsapp
#
# Produção WhatsApp — número aprovado pelo Meta em console.twilio.com
# Produção SMS     — número comprado em console.twilio.com; use TWILIO_CANAL=sms
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_CANAL=whatsapp

# ── E-mail SMTP (configurado em runtime via POST /setup) ───────────────────────
# As credenciais SMTP ficam armazenadas e criptografadas na tabela
# configuracaoAplicacao. Use o endpoint POST /setup para configurá-las.
# Não há variável de ambiente para SMTP — a troca de provedor é feita via API.
#
# Mailtrap Sandbox (dev):
#   smtpHost:     sandbox.smtp.mailtrap.io
#   smtpPort:     587
#   smtpUsername: <credencial-do-projeto-sandbox>
#   smtpPassword: <credencial-do-projeto-sandbox>
#   smtpStarttls: true
#
# Mailtrap Sending (prod):
#   smtpHost:     live.smtp.mailtrap.io
#   smtpPort:     587
#   smtpUsername: <credencial-do-dominio-sending>
#   smtpPassword: <credencial-do-dominio-sending>
#   smtpStarttls: true